# Exemplo de Variáveis de Ambiente para o Coopstar Express
# Copie este arquivo para .env.local e configure seus valores reais

# API Key de serviços (Ex: Google Maps se aplicável no futuro)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=sua_chave_aqui

# Integrações de Envio de Email (Ex: Resend API Key)
RESEND_API_KEY=re_sua_chave_aqui
CONTACT_EMAIL_DESTINATION=contato@coopstarexpress.com.br
